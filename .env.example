# MySQL Database
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_hatchery
MYSQL_PORT=3306

# Firebase Admin SDK (paste minified serviceAccountKey.json content)
# Option A: Path to JSON file (local development)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option B: Inline JSON string (Railway deployment - use this one)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# SMTP (for forgot password emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# TextBee SMS API
TEXTBEE_API_KEY=your_textbee_api_key
TEXTBEE_DEVICE_ID=your_textbee_device_id
TEXTBEE_PHONE_NUMBER=639XXXXXXXXX

# Alert Thresholds (optional - defaults shown)
ALERT_THRESHOLD_TEMPERATURE_MAX=32
ALERT_THRESHOLD_TEMPERATURE_MIN=20
ALERT_THRESHOLD_TDS_MAX=1000
ALERT_THRESHOLD_TURBIDITY_MAX=100
ALERT_THRESHOLD_EGG_COUNT_AVG=50
ALERT_COOLDOWN_MINUTES=30

# Server
PORT=3000
